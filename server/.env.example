PORT=4000
NODE_ENV=development

# Base de données MySQL (WAMP)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=hemolink

# Sécurité — JWT (changer en production !)
JWT_SECRET=hemolink-dev-secret-change-me-in-production-2026
JWT_EXPIRES_IN=12h

# Assistant IA — clé Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CORS — origines autorisées (séparées par virgule)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
